{
	"name": "seylu/wordpress-template",
	"description": "Generic WordPress template with Docker — development dependencies for static analysis and coding standards.",
	"type": "project",
	"license": "GPL-2.0-or-later",
	"require-dev": {
		"phpstan/phpstan": "^2.0",
		"szepeviktor/phpstan-wordpress": "^2.0",
		"wp-coding-standards/wpcs": "^3.0",
		"phpcompatibility/phpcompatibility-wp": "*",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"phpstan": "phpstan analyse --configuration=phpstan.neon.dist",
		"phpcs": "phpcs",
		"phpcbf": "phpcbf",
		"lint": [
			"@phpstan",
			"@phpcs"
		]
	}
}
