{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "xfact/hero",
	"version": "1.0.0",
	"title": "xFact Hero",
	"category": "theme",
	"icon": "format-video",
	"description": "Full-width hero section with background image slideshow, video overlay, and CTA.",
	"textdomain": "xfact",
	"attributes": {
		"title": {
			"type": "string",
			"default": "<accent>Your partner</accent> behind the systems communities rely on"
		},
		"subtitle": {
			"type": "string",
			"default": "xFact partners with public institutions to design, integrate, secure, and sustain mission-critical technology systems."
		},
		"buttons": {
			"type": "array",
			"default": []
		},
		"videoUrl": {
			"type": "string",
			"default": ""
		},
		"posterImage": {
			"type": "string",
			"default": ""
		},
		"slides": {
			"type": "array",
			"default": []
		},
		"showFloatingLogo": {
			"type": "string",
			"default": "global"
		},
		"align": {
			"type": "string",
			"default": "full"
		}
	},
	"supports": {
		"html": false,
		"align": [
			"full",
			"wide"
		],
		"spacing": {
			"padding": true
		}
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php",
	"style": "file:./style.css"
}
