{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "xfact/text-section",
	"version": "1.0.2",
	"title": "xFact Text Section",
	"category": "theme",
	"icon": "text",
	"description": "Text section with label, heading, body, optional badge and tags.",
	"textdomain": "xfact",
	"attributes": {
		"anchor": {
			"type": "string",
			"default": ""
		},
		"sectionLabel": {
			"type": "string",
			"default": ""
		},
		"sectionIcon": {
			"type": "string",
			"default": ""
		},
		"heading": {
			"type": "string",
			"default": ""
		},
		"body": {
			"type": "string",
			"default": ""
		},
		"badgeText": {
			"type": "string",
			"default": ""
		},
		"tags": {
			"type": "array",
			"default": []
		},
		"buttons": {
			"type": "array",
			"default": []
		},
		"useAltBackground": {
			"type": "boolean",
			"default": false
		},
		"isCenteredCard": {
			"type": "boolean",
			"default": false
		},
		"keyMessages": {
			"type": "array",
			"default": []
		},
		"keyMessagesHeading": {
			"type": "string",
			"default": "Why xFact"
		},
		"align": {
			"type": "string",
			"default": "full"
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": [
			"full",
			"wide"
		]
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php",
	"style": "file:./style.css"
}
