{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "xfact/section-list",
	"version": "1.0.0",
	"title": "xFact Section List",
	"category": "theme",
	"icon": "list-view",
	"description": "A vertical list of sections, each with a title and content. Can be numbered.",
	"textdomain": "xfact",
	"attributes": {
		"introText": { "type": "string", "default": "" },
		"showNumbers": { "type": "boolean", "default": true },
		"sections": { "type": "array", "default": [] }
	},
	"supports": { "html": false },
	"editorScript": "file:./index.js",
	"render": "file:./render.php",
	"style": "file:./style.css"
}
