{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "xfact/team-grid",
  "version": "1.0.0",
  "title": "xFact Team Grid",
  "category": "theme",
  "icon": "groups",
  "description": "Grid of team members.",
  "textdomain": "xfact",
  "attributes": {
    "sectionLabel": {
      "type": "string",
      "default": ""
    },
    "heading": {
      "type": "string",
      "default": ""
    },
    "teamMembers": {
      "type": "array",
      "default": []
    },
    "align": {
      "type": "string",
      "default": "full"
    }
  },
  "supports": {
    "html": false,
    "align": ["full", "wide"]
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php",
  "style": "file:./style.css"
}
