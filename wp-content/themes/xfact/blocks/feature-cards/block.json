{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "xfact/feature-cards",
	"version": "1.0.0",
	"title": "xFact Feature Cards",
	"category": "theme",
	"icon": "columns",
	"description": "Grid of feature/value cards with titles and descriptions.",
	"textdomain": "xfact",
	"attributes": {
		"sectionLabel": {
			"type": "string",
			"default": ""
		},
		"heading": {
			"type": "string",
			"default": ""
		},
		"cards": {
			"type": "array",
			"default": []
		},
		"align": {
			"type": "string",
			"default": "full"
		}
	},
	"supports": {
		"html": false,
		"align": [
			"full",
			"wide"
		]
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php",
	"style": "file:./style.css"
}
