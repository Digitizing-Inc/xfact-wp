{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "1280px",
			"wideSize": "1280px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{
					"slug": "primary",
					"color": "var(--xfact-semantic-primary)",
					"name": "Primary"
				},
				{
					"slug": "primary-dark",
					"color": "var(--xfact-semantic-primary-dark)",
					"name": "Primary Dark"
				},
				{
					"slug": "primary-light",
					"color": "var(--xfact-semantic-primary-light)",
					"name": "Primary Light"
				},
				{
					"slug": "text-primary",
					"color": "var(--xfact-semantic-text-primary)",
					"name": "Text Primary"
				},
				{
					"slug": "text-secondary",
					"color": "var(--xfact-semantic-text-secondary)",
					"name": "Text Secondary"
				},
				{
					"slug": "surface",
					"color": "var(--xfact-semantic-surface)",
					"name": "Surface"
				},
				{
					"slug": "surface-alt",
					"color": "var(--xfact-semantic-surface-alt)",
					"name": "Surface Alt"
				},
				{
					"slug": "success",
					"color": "var(--xfact-semantic-success)",
					"name": "Success"
				},
				{
					"slug": "warning",
					"color": "var(--xfact-semantic-warning)",
					"name": "Warning"
				},
				{
					"slug": "danger",
					"color": "var(--xfact-semantic-danger)",
					"name": "Danger"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				},
				{
					"slug": "black",
					"color": "#000000",
					"name": "Black"
				},
				{
					"slug": "transparent",
					"color": "transparent",
					"name": "Transparent"
				}
			],
			"gradients": [
				{
					"slug": "primary-1",
					"gradient": "var(--xfact-gradient-primary-1)",
					"name": "Primary 1"
				},
				{
					"slug": "primary-2",
					"gradient": "var(--xfact-gradient-primary-2)",
					"name": "Primary 2"
				},
				{
					"slug": "secondary-1",
					"gradient": "var(--xfact-gradient-secondary-1)",
					"name": "Secondary 1"
				},
				{
					"slug": "secondary-2",
					"gradient": "var(--xfact-gradient-secondary-2)",
					"name": "Secondary 2"
				},
				{
					"slug": "secondary-3",
					"gradient": "var(--xfact-gradient-secondary-3)",
					"name": "Secondary 3"
				},
				{
					"slug": "secondary-4",
					"gradient": "var(--xfact-gradient-secondary-4)",
					"name": "Secondary 4"
				}
			]
		},
		"typography": {
			"fluid": true,
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif",
					"slug": "inter",
					"name": "Inter",
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontWeight": "100 900",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/inter-latin.woff2"
							]
						},
						{
							"fontFamily": "Inter",
							"fontWeight": "100 900",
							"fontStyle": "italic",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/inter-latin-italic.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "'IBM Plex Mono', 'JetBrains Mono', Consolas, monospace",
					"slug": "ibm-plex-mono",
					"name": "IBM Plex Mono",
					"fontFace": [
						{
							"fontFamily": "IBM Plex Mono",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/ibm-plex-mono-latin-400-normal.woff2"
							]
						},
						{
							"fontFamily": "IBM Plex Mono",
							"fontWeight": "400",
							"fontStyle": "italic",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/ibm-plex-mono-latin-400-italic.woff2"
							]
						},
						{
							"fontFamily": "IBM Plex Mono",
							"fontWeight": "500",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/ibm-plex-mono-latin-500-normal.woff2"
							]
						},
						{
							"fontFamily": "IBM Plex Mono",
							"fontWeight": "600",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/ibm-plex-mono-latin-600-normal.woff2"
							]
						},
						{
							"fontFamily": "IBM Plex Mono",
							"fontWeight": "700",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/ibm-plex-mono-latin-700-normal.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', Consolas, monospace",
					"slug": "monospace",
					"name": "Monospace"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.875rem",
					"name": "Small",
					"fluid": {
						"min": "0.8rem",
						"max": "0.875rem"
					}
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium",
					"fluid": {
						"min": "0.9rem",
						"max": "1rem"
					}
				},
				{
					"slug": "large",
					"size": "1.25rem",
					"name": "Large",
					"fluid": {
						"min": "1.1rem",
						"max": "1.25rem"
					}
				},
				{
					"slug": "x-large",
					"size": "1.75rem",
					"name": "Extra Large",
					"fluid": {
						"min": "1.4rem",
						"max": "1.75rem"
					}
				},
				{
					"slug": "xx-large",
					"size": "2.5rem",
					"name": "2X Large",
					"fluid": {
						"min": "1.8rem",
						"max": "2.5rem"
					}
				},
				{
					"slug": "hero",
					"size": "3.75rem",
					"name": "Hero",
					"fluid": {
						"min": "1.875rem",
						"max": "3.75rem"
					}
				}
			]
		},
		"spacing": {
			"units": [
				"px",
				"em",
				"rem",
				"vh",
				"vw",
				"%"
			],
			"spacingScale": {
				"steps": 7,
				"mediumStep": 1.5,
				"unit": "rem",
				"operator": "*",
				"increment": 1.5
			}
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"presets": [
				{
					"name": "Small",
					"slug": "small",
					"shadow": "0 1px 2px 0 rgba(0, 0, 0, 0.05)"
				},
				{
					"name": "Medium",
					"slug": "medium",
					"shadow": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)"
				},
				{
					"name": "Large",
					"slug": "large",
					"shadow": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)"
				},
				{
					"name": "Accent Glow",
					"slug": "accent-glow",
					"shadow": "0 4px 12px rgba(92, 138, 230, 0.2)"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--surface)",
			"text": "var(--wp--preset--color--text-primary)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body, var(--wp--preset--font-family--ibm-plex-mono))",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.7"
		},
		"spacing": {
			"padding": {
				"top": "0",
				"right": "1rem",
				"bottom": "0",
				"left": "1rem"
			},
			"blockGap": "0"
		},
		"elements": {
			"heading": {
				"color": {
					"text": "var(--wp--preset--color--text-primary)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading, var(--wp--preset--font-family--inter))",
					"fontWeight": "700",
					"lineHeight": "1.3"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--hero)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"textDecoration": "underline"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary-dark)"
					},
					"typography": {
						"textDecoration": "none"
					}
				},
				":focus": {
					"color": {
						"text": "var(--wp--preset--color--primary-dark)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--white)"
				},
				"border": {
					"radius": "var(--xfact-glass-radius)",
					"width": "0"
				},
				"typography": {
					"fontWeight": "500",
					"fontSize": "var(--wp--preset--font-size--small)"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary-dark)",
						"text": "var(--wp--preset--color--white)"
					}
				},
				":focus": {
					"color": {
						"background": "var(--wp--preset--color--primary-dark)",
						"text": "var(--wp--preset--color--white)"
					}
				}
			},
			"caption": {
				"color": {
					"text": "var(--wp--preset--color--text-muted)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "700"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--white)"
						},
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--accent)"
							}
						}
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "500"
				}
			},
			"core/post-title": {
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--text-primary)"
						},
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--accent)"
							}
						}
					}
				}
			},
			"core/post-date": {
				"color": {
					"text": "var(--wp--preset--color--text-muted)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-excerpt": {
				"color": {
					"text": "var(--wp--preset--color--text-secondary)"
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--border)"
				},
				"border": {
					"color": "currentColor",
					"width": "0 0 1px 0",
					"style": "solid"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	]
}