{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "1280px",
			"wideSize": "1280px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{
					"slug": "navy-950",
					"color": "#09172f",
					"name": "Navy 950"
				},
				{
					"slug": "navy-900",
					"color": "#022038",
					"name": "Navy 900"
				},
				{
					"slug": "navy-800",
					"color": "#06384f",
					"name": "Navy 800"
				},
				{
					"slug": "navy-700",
					"color": "#0a4d6b",
					"name": "Navy 700"
				},
				{
					"slug": "navy-600",
					"color": "#32558f",
					"name": "Navy 600"
				},
				{
					"slug": "accent",
					"color": "var(--xfact-accent, #5C8AE6)",
					"name": "Accent"
				},
				{
					"slug": "accent-dark",
					"color": "#3A6BD4",
					"name": "Accent Dark"
				},
				{
					"slug": "accent-darkest",
					"color": "#123e99",
					"name": "Accent Darkest"
				},
				{
					"slug": "surface",
					"color": "var(--xfact-bg, #f5f7fa)",
					"name": "Surface"
				},
				{
					"slug": "surface-alt",
					"color": "var(--xfact-bg-alt, #ffffff)",
					"name": "Surface Alt"
				},
				{
					"slug": "surface-dark",
					"color": "#0d1f35",
					"name": "Surface Dark"
				},
				{
					"slug": "surface-raised",
					"color": "#06384f",
					"name": "Surface Raised"
				},
				{
					"slug": "border",
					"color": "#e2e8f0",
					"name": "Border"
				},
				{
					"slug": "text-primary",
					"color": "var(--xfact-text, #1a202c)",
					"name": "Text Primary"
				},
				{
					"slug": "text-secondary",
					"color": "var(--xfact-text-secondary, #4a5568)",
					"name": "Text Secondary"
				},
				{
					"slug": "text-muted",
					"color": "#718096",
					"name": "Text Muted"
				},
				{
					"slug": "dark-section",
					"color": "#0d2d6b",
					"name": "Dark Section"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				}
			],
			"gradients": [
				{
					"slug": "button-primary",
					"gradient": "linear-gradient(90deg, var(--wp--preset--color--accent-darkest) 0%, var(--wp--preset--color--accent-dark) 100%)",
					"name": "Button Primary"
				},
				{
					"slug": "button-hover",
					"gradient": "linear-gradient(90deg, var(--wp--preset--color--accent-dark) 0%, var(--wp--preset--color--accent) 100%)",
					"name": "Button Hover"
				}
			]
		},
		"typography": {
			"fluid": true,
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif",
					"slug": "body",
					"name": "Body (Inter)",
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontWeight": "100 900",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/inter-latin.woff2"
							]
						},
						{
							"fontFamily": "Inter",
							"fontWeight": "100 900",
							"fontStyle": "italic",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/inter-latin-italic.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', Consolas, monospace",
					"slug": "monospace",
					"name": "Monospace"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.875rem",
					"name": "Small",
					"fluid": {
						"min": "0.8rem",
						"max": "0.875rem"
					}
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium",
					"fluid": {
						"min": "0.9rem",
						"max": "1rem"
					}
				},
				{
					"slug": "large",
					"size": "1.25rem",
					"name": "Large",
					"fluid": {
						"min": "1.1rem",
						"max": "1.25rem"
					}
				},
				{
					"slug": "x-large",
					"size": "1.75rem",
					"name": "Extra Large",
					"fluid": {
						"min": "1.4rem",
						"max": "1.75rem"
					}
				},
				{
					"slug": "xx-large",
					"size": "2.5rem",
					"name": "2X Large",
					"fluid": {
						"min": "1.8rem",
						"max": "2.5rem"
					}
				},
				{
					"slug": "hero",
					"size": "3.75rem",
					"name": "Hero",
					"fluid": {
						"min": "1.875rem",
						"max": "3.75rem"
					}
				}
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "vh", "vw", "%"],
			"spacingScale": {
				"steps": 7,
				"mediumStep": 1.5,
				"unit": "rem",
				"operator": "*",
				"increment": 1.5
			}
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"presets": [
				{
					"name": "Small",
					"slug": "small",
					"shadow": "0 1px 2px 0 rgba(0, 0, 0, 0.05)"
				},
				{
					"name": "Medium",
					"slug": "medium",
					"shadow": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)"
				},
				{
					"name": "Large",
					"slug": "large",
					"shadow": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)"
				},
				{
					"name": "Accent Glow",
					"slug": "accent-glow",
					"shadow": "0 4px 12px rgba(92, 138, 230, 0.2)"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--surface)",
			"text": "var(--wp--preset--color--text-primary)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.7"
		},
		"spacing": {
			"padding": {
				"top": "0",
				"right": "1rem",
				"bottom": "0",
				"left": "1rem"
			},
			"blockGap": "0"
		},
		"elements": {
			"heading": {
				"color": {
					"text": "var(--wp--preset--color--text-primary)"
				},
				"typography": {
					"fontWeight": "700",
					"lineHeight": "1.3"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--hero)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent)"
				},
				"typography": {
					"textDecoration": "underline"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--accent-dark)"
					},
					"typography": {
						"textDecoration": "none"
					}
				},
				":focus": {
					"color": {
						"text": "var(--wp--preset--color--accent-dark)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--accent-darkest)",
					"text": "var(--wp--preset--color--white)"
				},
				"border": {
					"radius": "0",
					"width": "0"
				},
				"typography": {
					"fontWeight": "500",
					"fontSize": "var(--wp--preset--font-size--small)"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--accent-dark)",
						"text": "var(--wp--preset--color--white)"
					}
				},
				":focus": {
					"color": {
						"background": "var(--wp--preset--color--accent-dark)",
						"text": "var(--wp--preset--color--white)"
					}
				}
			},
			"caption": {
				"color": {
					"text": "var(--wp--preset--color--text-muted)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "700"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--white)"
						},
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--accent)"
							}
						}
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "500"
				}
			},
			"core/post-title": {
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--text-primary)"
						},
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--accent)"
							}
						}
					}
				}
			},
			"core/post-date": {
				"color": {
					"text": "var(--wp--preset--color--text-muted)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-excerpt": {
				"color": {
					"text": "var(--wp--preset--color--text-secondary)"
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--border)"
				},
				"border": {
					"color": "currentColor",
					"width": "0 0 1px 0",
					"style": "solid"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	]
}
