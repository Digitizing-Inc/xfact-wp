{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "800px",
			"wideSize": "1200px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{
					"slug": "primary",
					"color": "#1e40af",
					"name": "Primary"
				},
				{
					"slug": "primary-light",
					"color": "#3b82f6",
					"name": "Primary Light"
				},
				{
					"slug": "secondary",
					"color": "#7c3aed",
					"name": "Secondary"
				},
				{
					"slug": "accent",
					"color": "#06b6d4",
					"name": "Accent"
				},
				{
					"slug": "surface",
					"color": "#ffffff",
					"name": "Surface"
				},
				{
					"slug": "surface-alt",
					"color": "#f8fafc",
					"name": "Surface Alt"
				},
				{
					"slug": "border",
					"color": "#e2e8f0",
					"name": "Border"
				},
				{
					"slug": "text-primary",
					"color": "#0f172a",
					"name": "Text Primary"
				},
				{
					"slug": "text-secondary",
					"color": "#475569",
					"name": "Text Secondary"
				},
				{
					"slug": "text-muted",
					"color": "#94a3b8",
					"name": "Text Muted"
				},
				{
					"slug": "success",
					"color": "#16a34a",
					"name": "Success"
				},
				{
					"slug": "warning",
					"color": "#d97706",
					"name": "Warning"
				},
				{
					"slug": "error",
					"color": "#dc2626",
					"name": "Error"
				}
			]
		},
		"typography": {
			"fluid": true,
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif",
					"slug": "body",
					"name": "Body (Inter)",
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontWeight": "100 900",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"https://fonts.gstatic.com/s/inter/v18/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIw2boKoduKmMEVuLyfAZ9hiJ-Ek-_EeA.woff2"
							]
						},
						{
							"fontFamily": "Inter",
							"fontWeight": "100 900",
							"fontStyle": "italic",
							"fontDisplay": "swap",
							"src": [
								"https://fonts.gstatic.com/s/inter/v18/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIw2boKoduKmMEVuI6fAZ9hiJ-Ek-_EeA.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', Consolas, monospace",
					"slug": "monospace",
					"name": "Monospace"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.875rem",
					"name": "Small",
					"fluid": {
						"min": "0.8rem",
						"max": "0.875rem"
					}
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium",
					"fluid": {
						"min": "0.9rem",
						"max": "1rem"
					}
				},
				{
					"slug": "large",
					"size": "1.25rem",
					"name": "Large",
					"fluid": {
						"min": "1.1rem",
						"max": "1.25rem"
					}
				},
				{
					"slug": "x-large",
					"size": "1.75rem",
					"name": "Extra Large",
					"fluid": {
						"min": "1.4rem",
						"max": "1.75rem"
					}
				},
				{
					"slug": "xx-large",
					"size": "2.5rem",
					"name": "2X Large",
					"fluid": {
						"min": "1.8rem",
						"max": "2.5rem"
					}
				},
				{
					"slug": "xxx-large",
					"size": "3.5rem",
					"name": "3X Large",
					"fluid": {
						"min": "2.2rem",
						"max": "3.5rem"
					}
				}
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "vh", "vw", "%"],
			"spacingScale": {
				"steps": 7,
				"mediumStep": 1.5,
				"unit": "rem",
				"operator": "*",
				"increment": 1.5
			}
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true,
			"radiusSizes": [
				{
					"name": "Small",
					"slug": "small",
					"size": "4px"
				},
				{
					"name": "Medium",
					"slug": "medium",
					"size": "8px"
				},
				{
					"name": "Large",
					"slug": "large",
					"size": "16px"
				},
				{
					"name": "Full",
					"slug": "full",
					"size": "9999px"
				}
			]
		},
		"shadow": {
			"presets": [
				{
					"name": "Small",
					"slug": "small",
					"shadow": "0 1px 2px 0 rgba(0, 0, 0, 0.05)"
				},
				{
					"name": "Medium",
					"slug": "medium",
					"shadow": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)"
				},
				{
					"name": "Large",
					"slug": "large",
					"shadow": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)"
				},
				{
					"name": "XL",
					"slug": "xl",
					"shadow": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1)"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--surface)",
			"text": "var(--wp--preset--color--text-primary)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.7"
		},
		"spacing": {
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--40)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--40)"
			},
			"blockGap": "var(--wp--preset--spacing--40)"
		},
		"elements": {
			"heading": {
				"color": {
					"text": "var(--wp--preset--color--text-primary)"
				},
				"typography": {
					"fontWeight": "700",
					"lineHeight": "1.3"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xxx-large)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"textDecoration": "underline"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary-light)"
					},
					"typography": {
						"textDecoration": "none"
					}
				},
				":focus": {
					"color": {
						"text": "var(--wp--preset--color--primary-light)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--surface)"
				},
				"border": {
					"radius": "var(--wp--preset--border-radius--medium)",
					"width": "0"
				},
				"typography": {
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--medium)"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary-light)",
						"text": "var(--wp--preset--color--surface)"
					}
				},
				":focus": {
					"color": {
						"background": "var(--wp--preset--color--primary-light)",
						"text": "var(--wp--preset--color--surface)"
					}
				}
			},
			"caption": {
				"color": {
					"text": "var(--wp--preset--color--text-muted)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"input": {
				"border": {
					"color": "var(--wp--preset--color--border)",
					"radius": "var(--wp--preset--border-radius--medium)",
					"width": "1px"
				},
				"color": {
					"background": "var(--wp--preset--color--surface)",
					"text": "var(--wp--preset--color--text-primary)"
				},
				"spacing": {
					"padding": {
						"top": "0.5rem",
						"right": "0.75rem",
						"bottom": "0.5rem",
						"left": "0.75rem"
					}
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "700"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--text-primary)"
						},
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--primary)"
							}
						}
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "500"
				}
			},
			"core/post-title": {
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--text-primary)"
						},
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--primary)"
							}
						}
					}
				}
			},
			"core/post-date": {
				"color": {
					"text": "var(--wp--preset--color--text-muted)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-excerpt": {
				"color": {
					"text": "var(--wp--preset--color--text-secondary)"
				}
			},
			"core/code": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--monospace)",
					"fontSize": "var(--wp--preset--font-size--small)"
				},
				"color": {
					"background": "var(--wp--preset--color--surface-alt)",
					"text": "var(--wp--preset--color--text-primary)"
				},
				"border": {
					"radius": "var(--wp--preset--border-radius--medium)",
					"color": "var(--wp--preset--color--border)",
					"width": "1px"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--30)",
						"right": "var(--wp--preset--spacing--40)",
						"bottom": "var(--wp--preset--spacing--30)",
						"left": "var(--wp--preset--spacing--40)"
					}
				}
			},
			"core/quote": {
				"border": {
					"color": "var(--wp--preset--color--primary)",
					"width": "0 0 0 4px",
					"style": "solid"
				},
				"spacing": {
					"padding": {
						"left": "var(--wp--preset--spacing--40)"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--text-secondary)"
				},
				"typography": {
					"fontStyle": "italic"
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--border)"
				},
				"border": {
					"color": "currentColor",
					"width": "0 0 1px 0",
					"style": "solid"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	]
}
