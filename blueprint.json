{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/",
  "meta": {
    "title": "xFact WordPress Theme Preview",
    "author": "seyLu"
  },
  "preferredVersions": {
    "php": "8.3",
    "wp": "latest"
  },
  "features": {
    "networking": true
  },
  "login": true,
  "steps": [
    {
      "step": "installTheme",
      "themeData": {
        "resource": "git:directory",
        "url": "https://github.com/seyLu/xfact-wp",
        "ref": "main",
        "refType": "branch",
        "path": "/wp-content/themes/xfact"
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "writeFiles",
      "writeToPath": "/wordpress/wp-content/mu-plugins/",
      "filesTree": {
        "resource": "git:directory",
        "url": "https://github.com/seyLu/xfact-wp",
        "ref": "main",
        "refType": "branch",
        "path": "/wp-content/mu-plugins"
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "wordpress.org/plugins",
        "slug": "contact-form-7"
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "wordpress.org/plugins",
        "slug": "flamingo"
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "setSiteOptions",
      "options": {
        "blogname": "xFact",
        "blogdescription": "Technology services that deliver results for public-sector organizations.",
        "show_on_front": "page"
      }
    },
    {
      "step": "wp-cli",
      "command": "wp rewrite structure '/%postname%/' --hard"
    }
  ]
}
